rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, update, delete: if isOwner(uid);
      allow create: if isOwner(uid) && request.resource.data.uid == uid;

      match /stashCollections/{collectionId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && request.resource.data.ownerUid == uid;

        match /yarns/{yarnId} {
          allow read, delete: if isOwner(uid);
          allow create, update: if isOwner(uid)
            && request.resource.data.ownerUid == uid
            && request.resource.data.collectionId == collectionId;
        }

        match /folders/{folderId} {
          allow read: if isOwner(uid);
          allow create: if isOwner(uid)
            && request.resource.data.ownerUid == uid
            && request.resource.data.collectionId == collectionId
            && (
              folderId == 'used-up' ||
              request.resource.data.isSystem == false
            );
          allow update: if isOwner(uid)
            && request.resource.data.ownerUid == uid
            && request.resource.data.collectionId == collectionId
            && (
              (
                folderId == 'used-up' &&
                request.resource.data.isSystem == true
              ) ||
              (
                folderId != 'used-up' &&
                request.resource.data.isSystem == resource.data.isSystem
              )
            );
          allow delete: if isOwner(uid)
            && folderId != 'used-up'
            && resource.data.isSystem != true;
        }
      }
    }
  }
}
